{
  "name": "@orbit/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/app.ts",
    "build": "tsup src/app.ts --format esm --out-dir dist --no-splitting",
    "start": "node dist/app.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/oauth2": "^8.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@google-cloud/storage": "^7.16.0",
    "@neondatabase/serverless": "^0.10.4",
    "@orbit/shared": "workspace:*",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.43.1",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.1.0",
    "nanoid": "^5.1.5",
    "node-cron": "^3.0.3",
    "pino-pretty": "^13.0.0",
    "resend": "^4.5.1",
    "web-push": "^3.6.7",
    "ws": "^8.18.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@orbit/shared": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/node-cron": "^3.0.11",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
